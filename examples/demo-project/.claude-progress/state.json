      "findings": [
        {
          "id": "f_aa20000001",
          "title": "Server sessions chosen over JWT",
          "body": "Revocation is trivial (one DELETE). JWT denylist would re-introduce DB state we wanted to avoid in the first place. Session lookup is O(1) on indexed sid; cache later if needed.",
          "createdAt": "2026-04-12T15:40:00+00:00",
          "updatedAt": "2026-04-12T15:40:00+00:00"
        },
        {
          "id": "f_aa20000002",
          "title": "bcrypt cost factor 12 is the right balance",
          "body": "~250ms hash on a 2024 MBP. Login latency is dominated by network anyway. Cost 14 was tested but added 1+ second on signup which was visibly slow in the UI.",
          "createdAt": "2026-04-14T11:25:00+00:00",
          "updatedAt": "2026-04-14T11:25:00+00:00"
        }
      ],
      "createdAt": "2026-04-12T09:00:00+00:00",
      "updatedAt": "2026-04-23T10:00:00+00:00"
